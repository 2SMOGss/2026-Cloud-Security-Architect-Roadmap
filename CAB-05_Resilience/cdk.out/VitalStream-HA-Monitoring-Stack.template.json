{
 "Resources": {
  "VitalStreamBillingAlarm": {
   "Type": "AWS::CloudWatch::Alarm",
   "Properties": {
    "AlarmDescription": "Alarm when estimated charges exceed $10",
    "AlarmName": "VitalStream-CAB05-BillingAlarm",
    "ComparisonOperator": "GreaterThanThreshold",
    "Dimensions": [
     {
      "Name": "Currency",
      "Value": "USD"
     }
    ],
    "EvaluationPeriods": 1,
    "MetricName": "EstimatedCharges",
    "Namespace": "AWS/Billing",
    "Period": 21600,
    "Statistic": "Maximum",
    "Tags": [
     {
      "Key": "Monitoring",
      "Value": "Financial"
     }
    ],
    "Threshold": 10
   },
   "Metadata": {
    "aws:cdk:path": "VitalStream-HA-Monitoring-Stack/VitalStream-BillingAlarm"
   }
  },
  "CDKMetadata": {
   "Type": "AWS::CDK::Metadata",
